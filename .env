# Base URL for backend API (no trailing slash)
# Example backend URL: https://retrorsely-uncondensational-bentlee.ngrok-free.dev
VITE_API_BASE_URL=https://retrorsely-uncondensational-bentlee.ngrok-free.dev

# API prefix used by the patients endpoint
# Final patients URL becomes: {VITE_API_BASE_URL}{VITE_API_PREFIX}/patients
VITE_API_PREFIX=/api/v1

# Optional fallback endpoint when /patients is unavailable or empty
# Final fallback URL becomes: {VITE_API_BASE_URL}{VITE_DASHBOARD_DATA_PATH}
VITE_DASHBOARD_DATA_PATH=/api/care-dashboard-data
